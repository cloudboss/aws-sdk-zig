#!/usr/bin/env python3
"""
Generates an index.html for the docs output directory that links to
each service's autodoc page and the runtime library docs.

Usage: generate-docs-index <docs-dir> <services-txt> <models-dir>
"""

import json
import os
import sys


def load_service_metadata(services_txt, models_dir):
    """Parse services.txt and extract smithy.api#title from each model JSON."""
    metadata = {}
    with open(services_txt) as f:
        for line in f:
            parts = line.strip().split()
            if len(parts) < 3:
                continue
            module, model_path = parts[0], parts[1]
            json_path = os.path.join(models_dir, model_path)
            title = extract_title(json_path)
            metadata[module] = title if title else module
    return metadata


def extract_title(json_path):
    """Extract the smithy.api#title trait from a Smithy model JSON file."""
    try:
        with open(json_path) as f:
            data = json.load(f)
    except (OSError, json.JSONDecodeError):
        return None
    for shape in data.get("shapes", {}).values():
        if shape.get("type") == "service":
            return shape.get("traits", {}).get("smithy.api#title")
    return None


def discover_services(docs_dir):
    """Find service directories that contain generated docs."""
    services = []
    for entry in os.listdir(docs_dir):
        if entry == "aws":
            continue
        index = os.path.join(docs_dir, entry, "index.html")
        if os.path.isfile(index):
            services.append(entry)
    return services


