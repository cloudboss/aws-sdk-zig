      const list = document.getElementById('serviceList');
      const items = Array.from(list.getElementsByTagName('li'));
      search.addEventListener('input', function() {
        const q = this.value.toLowerCase();
        items.forEach(function(li) {
          li.style.display = li.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
      });
    </script>
  </body>
</html>
"""


def main():
    if len(sys.argv) != 4:
        print(f"Usage: {sys.argv[0]} <docs-dir> <services-txt> <models-dir>", file=sys.stderr)
        sys.exit(1)

    docs_dir = sys.argv[1]
    services_txt = sys.argv[2]
    models_dir = sys.argv[3]

    metadata = load_service_metadata(services_txt, models_dir)
    modules = discover_services(docs_dir)

    # Build (display_name, module) pairs and sort alphabetically by display name
    entries = []
    for module in modules:
        display = metadata.get(module, module)
        entries.append((display, module))
    entries.sort(key=lambda e: e[0].casefold())

    out_path = os.path.join(docs_dir, "index.html")
    with open(out_path, "w") as f:
        f.write(HTML_HEADER)
        f.write(f'        <h2>Services <span style="font-weight:normal;font-size:0.8em">({len(entries)})</span></h2>\n')
        f.write('        <ul class="columns" id="serviceList">\n')
        for display, module in entries:
            f.write(f'          <li><a href="{module}/index.html">{display}</a></li>\n')
        f.write(HTML_FOOTER)

    print(f"Generated {out_path} with {len(entries)} services")


if __name__ == "__main__":
    main()
