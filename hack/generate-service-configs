#!/usr/bin/env python3
"""Generate smithy-build.json and services.txt for all AWS services."""

import json
import os
import sys

AWS_MODELS_COMMIT = os.environ.get("AWS_MODELS_COMMIT", "")
if not AWS_MODELS_COMMIT:
    print("Error: AWS_MODELS_COMMIT environment variable not set", file=sys.stderr)
    sys.exit(1)

MODELS_BASE = os.path.join(
    os.path.dirname(__file__),
    "..",
    "_output",
    f"api-models-aws-{AWS_MODELS_COMMIT}",
    "models",
)
SMITHY_BUILD_OUT = os.path.join(
    os.path.dirname(__file__), "..", "codegen", "sdk-codegen", "smithy-build.json"
)
SERVICES_TXT_OUT = os.path.join(os.path.dirname(__file__), "services.txt")

SUPPORTED_PROTOCOLS = {
    "aws.protocols#awsJson1_0",
    "aws.protocols#awsJson1_1",
    "aws.protocols#restJson1",
    "aws.protocols#awsQuery",
    "aws.protocols#restXml",
    "aws.protocols#ec2Query",
}


def find_service_shape(model):
    """Find the service shape ID and its traits in a Smithy model."""
    for shape_id, shape in model["shapes"].items():
        if shape.get("type") == "service":
            return shape_id, shape.get("traits", {})
    return None, None


def is_rpcv2_only(traits):
    """Check if a service only supports rpcv2Cbor with no fallback protocol."""
    if "smithy.protocols#rpcv2Cbor" not in traits:
        return False
    for proto in SUPPORTED_PROTOCOLS:
        if proto in traits:
            return False
    return True


def scan_models(models_base):
    """Scan the models directory and return service info, sorted by package name."""
    services = []
    skipped = []

    for svc_dir in sorted(os.listdir(models_base)):
        service_path = os.path.join(models_base, svc_dir, "service")
        if not os.path.isdir(service_path):
            skipped.append((svc_dir, "no service/ subdirectory"))
            continue

        dates = sorted(os.listdir(service_path))
        if not dates:
            skipped.append((svc_dir, "empty service/ directory"))
            continue

        date = dates[-1]
        model_filename = f"{svc_dir}-{date}.json"
        model_path = os.path.join(service_path, date, model_filename)

        if not os.path.exists(model_path):
            skipped.append((svc_dir, f"model file not found: {model_filename}"))
            continue

        try:
            with open(model_path) as f:
                model = json.load(f)
        except (json.JSONDecodeError, OSError) as e:
            skipped.append((svc_dir, f"failed to parse model: {e}"))
            continue

        shape_id, traits = find_service_shape(model)
        if shape_id is None:
            skipped.append((svc_dir, "no service shape found"))
            continue

        if is_rpcv2_only(traits):
            skipped.append((svc_dir, "rpcv2Cbor only"))
            continue

        package_name = svc_dir.replace("-", "")
        rel_model_path = f"models/{svc_dir}/service/{date}/{model_filename}"

        services.append((package_name, svc_dir, rel_model_path, shape_id))

    services.sort(key=lambda s: s[0])
    return services, skipped


def write_smithy_build(services, output_path):
    """Write smithy-build.json with all service projections."""
    projections = {}
    for package_name, _, _, shape_id in services:
        projections[package_name] = {
            "plugins": {
                "zig-codegen": {
                    "service": shape_id,
                    "package": package_name,
                }
            }
        }

    smithy_build = {
        "version": "1.0",
        "sources": ["model"],
        "projections": projections,
    }

    os.makedirs(os.path.dirname(output_path), exist_ok=True)
    with open(output_path, "w") as f:
        json.dump(smithy_build, f, indent=4, sort_keys=False)
        f.write("\n")


def write_services_txt(services, output_path):
    """Write services.txt with one line per service (space-separated)."""
    os.makedirs(os.path.dirname(output_path), exist_ok=True)
    with open(output_path, "w") as f:
        for package_name, _, rel_model_path, shape_id in services:
            f.write(f"{package_name} {rel_model_path} {shape_id}\n")


def main():
    models_base = os.path.realpath(MODELS_BASE)
    if not os.path.isdir(models_base):
        print(f"Error: models directory not found: {models_base}", file=sys.stderr)
        sys.exit(1)

    services, skipped = scan_models(models_base)

    smithy_out = os.path.realpath(SMITHY_BUILD_OUT)
    services_txt_out = os.path.realpath(SERVICES_TXT_OUT)

    write_smithy_build(services, smithy_out)
    write_services_txt(services, services_txt_out)

    print(f"Generated {len(services)} service projections")
    if skipped:
        print(f"Skipped {len(skipped)} services:")
        for name, reason in skipped:
            print(f"  {name}: {reason}")
    print(f"Written: {smithy_out}")
    print(f"Written: {services_txt_out}")


if __name__ == "__main__":
    main()
